# === Application ===
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# === LinkedIn OAuth 2.0 ===
# Create your app at https://developer.linkedin.com/
# Enable "Sign In with LinkedIn using OpenID Connect" and "Share on LinkedIn" products
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/linkedin/callback

# === OpenAI API / Gemini API (Free Tier) ===
# Used for generating and rewriting LinkedIn post drafts.
# You can use OpenAI OR a free API like Google Gemini (which is 100% free via Google AI Studio).
# 
# Option A: OpenAI (Paid)
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE=
# 
# Option B: Google Gemini API (100% Free via AI Studio - recommended if you want free service)
# Get key here: https://aistudio.google.com/
OPENAI_API_KEY=your-gemini-api-key-here
OPENAI_MODEL=gemini-2.5-flash
OPENAI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai/

# === Scheduling ===
# Daily post time in America/Phoenix timezone (MST, no daylight saving)
TIMEZONE=America/Phoenix
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=0

# === Token Encryption ===
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-encryption-key

# === GitHub (Optional) ===
# Set your GitHub username to fetch repositories for Monday project spotlights
GITHUB_USERNAME=your-github-username

